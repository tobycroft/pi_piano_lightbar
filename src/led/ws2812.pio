; Standard WS2812/SK6812 LED driver PIO program
; Timing: 800KHz bit rate, 9 SM cycles per bit
;   Bit 1: 5 high, 4 low  = ~690ns high, ~552ns low  @ 7.2MHz
;   Bit 0: 2 high, 7 low  = ~276ns high, ~966ns low  @ 7.2MHz
;
.program ws2812
.side_set 1

.wrap_target
bitloop:
    out x, 1       side 0 [3]
    jmp !x, do_zero side 1 [1]
    jmp bitloop     side 1 [2]
do_zero:
    nop side 0 [2]
.wrap